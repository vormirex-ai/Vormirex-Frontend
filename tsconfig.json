{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "jsx": "react-jsx",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,

    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "src/global.d.ts"],
  "exclude": ["node_modules", "dist"]
}
